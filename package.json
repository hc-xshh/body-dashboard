{
  "name": "body-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync:training": "python3 scripts/sync_training_plan_from_obsidian.py",
    "build": "npm run sync:plans && vite build",
    "lint": "eslint .",
    "replay:rules": "node scripts/replay-rules-engine.js",
    "preview": "vite preview",
    "sync:diet": "python3 scripts/sync_diet_plan_from_obsidian.py",
    "sync:skincare": "python3 scripts/sync_skincare_plan_from_obsidian.py",
    "sync:plans": "npm run sync:training && npm run sync:diet && npm run sync:skincare && python3 scripts/validate_generated_plans.py"
  },
  "dependencies": {
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12"
  }
}
